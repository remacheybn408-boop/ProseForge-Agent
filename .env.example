# ProseForge Agent environment file (Task 191).
# Copy to `.env` (or `.env.local`) and fill in values. `.env` is gitignored.
# Existing shell environment variables are never overridden by this file.
# Precedence (higher wins): shell env > .env.local > .env > machine defaults.

# --- ProseForge engine boundary ---
# Absolute path to your canonical ProseForge engine checkout.
PROSEFORGE_ROOT=

# Portable workspace root the agent owns (defaults to .pf-agent).
PROSEFORGE_AGENT_WORKSPACE=.pf-agent

# --- Onboarding ---
# Set to 1 in CI/non-interactive environments to skip first-run onboarding.
PF_AGENT_SKIP_FIRST_RUN=

# --- Provider API keys (store here or in your OS secret manager) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# --- Publishing (used by `pf-agent release publish`) ---
TWINE_USERNAME=__token__
TWINE_PASSWORD=

# --- Encoding (usually set automatically by the bootstrap on Windows) ---
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
